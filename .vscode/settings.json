{
    "files.watcherExclude": {
        "**/data/**": true,
        "**/__pycache__/**": true,
        "**/*.tif": true,
        "**/*.csv": true,
        "**/*.{asc,atx,gdbtablx,gdbtable,gdbindexes,freelist,spx,horizon,aux.xml}": true
    },
    "search.exclude": {
        "**/data/**": true,
        "**/__pycache__/**": true,
        "**/*.{tif,csv,asc,atx,gdbtablx,gdbtable,gdbindexes,freelist,spx,horizon}": true
    },
    "python.analysis.exclude": [
        "**/data/**",
        "**/__pycache__/**"
    ],
    "python.analysis.indexing": false,
    "python.analysis.diagnosticMode": "openFilesOnly"
}
